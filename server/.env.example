# Database
MONGO_URI=mongodb://user:password@cluster.mongodb.net/?ssl=true

# Server
PORT=5000

# Authentication
JWT_SECRET=your_secret_key_here

# LeetCode API (optional, for parsing LeetCode profiles)
# LEETCODE_API_BASE=https://leetcode-api.com

# AI Recommendations (optional - choose one provider)
# OpenAI
# OPENAI_API_KEY=your_openai_api_key
# OPENAI_MODEL=gpt-4o-mini

# Anthropic
# ANTHROPIC_API_KEY=your_anthropic_api_key
# ANTHROPIC_MODEL=claude-3-5-haiku-latest

# Google Gemini
# GOOGLE_GEMINI_API_KEY=your_google_gemini_api_key
# GOOGLE_GEMINI_MODEL=gemini-2.0-flash

# CORS Configuration (comma-separated URLs)
# ALLOWED_ORIGIN=http://localhost:5173,http://localhost:3000
